# Puerto del servidor
PORT=3000

# Firebase Configuration
FIREBASE_PROJECT_ID=apptransportettc
FIREBASE_DATABASE_NAME=transporte-db

# Firebase Service Account (OPCIONAL - Solo para Docker/Easypanel)
# Si usas Docker sin gcloud CLI, pega aquí el contenido de tu firebase-key.json en una sola línea
# Ejemplo: FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...",...}'
# IMPORTANTE: Debe ser un JSON válido en una sola línea, entre comillas simples
# Si no se proporciona, el sistema usará:
#   1. Archivo firebase-key.json (desarrollo local)
#   2. Application Default Credentials de gcloud (recomendado)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Wialon API
WIALON_API_URL=https://hst-api.wialon.com/wialon/ajax.html

# Nimbus API
NIMBUS_API_URL=https://nimbus.wialon.com/api

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
